# CareerOS environment example.
# Copy to `.env` for local overrides: `cp .env.example .env`
# `.env` and `.env.<environment>` are git-ignored. Never commit real secrets.
#
# Full documentation: docs/environments.md
# Local developer setup: docs/development.md
#
# docker compose already ships local-dev-safe defaults, so `.env` is optional
# when you only use `docker compose up` (still copy keys after `supabase start`
# before exercising auth).

# --- Postgres (local container / docker compose) ---
# App schema lives here (Alembic → CAREEROS_DATABASE_URL).
# Supabase CLI runs a separate Auth DB on port 54322 — do not point this URL there.
POSTGRES_USER=careeros
POSTGRES_PASSWORD=careeros
POSTGRES_DB=careeros
POSTGRES_PORT=5432

# --- Application settings (env prefix CAREEROS_) ---
# Source of truth: shared/platform/careeros_platform/settings.py
# Every field on Settings must appear here.

CAREEROS_ENVIRONMENT=development
CAREEROS_LOG_LEVEL=INFO
CAREEROS_APP_NAME=career-os

# Required by api/worker (fail-fast if missing when running outside compose).
# docker compose sets an in-cluster URL automatically (host `postgres`);
# use this localhost URL when running api/worker on the host against compose Postgres.
CAREEROS_DATABASE_URL=postgresql://careeros:careeros@localhost:5432/careeros

# api bind + port (compose forces host 0.0.0.0 inside the container).
CAREEROS_API_HOST=127.0.0.1
CAREEROS_API_PORT=8000

# --- Supabase Auth (local CLI) ---
# After `supabase start`, prefer `supabase status -o env` and sync these values.
# Defaults below match the classic local JWT secret shipped in supabase/config.toml
# (LOCAL DEV ONLY — never reuse in staging/production).
CAREEROS_SUPABASE_URL=http://127.0.0.1:54321
# Optional: override JWKS fetch URL (compose defaults to host.docker.internal).
# CAREEROS_SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
CAREEROS_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
CAREEROS_SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
CAREEROS_SUPABASE_JWT_AUDIENCE=authenticated

# --- Job Intelligence (ADR-0001) ---
# Comma-separated kind:board_token (public ATS feeds).
CAREEROS_OPPORTUNITY_BOARDS=greenhouse:stripe,greenhouse:gitlab
CAREEROS_INGESTION_INTERVAL_SECONDS=3600
CAREEROS_MATCH_MIN_SCORE=0.55
CAREEROS_OPPORTUNITY_ACTIVE_LIMIT=400

# --- Web (Next.js) ---
# Same URL/anon key as above; never put a service-role key in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Server-side API base (web Server Components / BFF). Browser uses host port.
CAREEROS_API_BASE_URL=http://127.0.0.1:8000

# Optional Google OAuth (enable [auth.external.google] in supabase/config.toml).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Ports published to the host (docker compose only) ---
WEB_PORT=3000
