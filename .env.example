# CareerOS environment example (M0-T14).
# Copy to `.env` for local overrides: `cp .env.example .env`
# `.env` is git-ignored. The full configuration surface is documented in T16.
# docker compose already ships local-dev-safe defaults, so `.env` is optional.

# --- Postgres (local container) ---
POSTGRES_USER=careeros
POSTGRES_PASSWORD=careeros
POSTGRES_DB=careeros
POSTGRES_PORT=5432

# --- Application settings (env prefix CAREEROS_) ---
CAREEROS_ENVIRONMENT=development
CAREEROS_LOG_LEVEL=INFO
CAREEROS_APP_NAME=career-os

# Required by the api/worker. In docker compose this is set automatically to the
# in-cluster Postgres URL; override only when running outside compose.
# CAREEROS_DATABASE_URL=postgresql://careeros:careeros@localhost:5432/careeros

# api bind + port (compose forces host 0.0.0.0 inside the container).
CAREEROS_API_HOST=127.0.0.1
CAREEROS_API_PORT=8000

# --- Ports published to the host ---
WEB_PORT=3000
