# CareerOS environment example (M0-T16).
# Copy to `.env` for local overrides: `cp .env.example .env`
# `.env` and `.env.<environment>` are git-ignored. Never commit real secrets.
#
# Full documentation: docs/environments.md
# Local developer setup: docs/development.md
#
# docker compose already ships local-dev-safe defaults, so `.env` is optional
# when you only use `docker compose up`.

# --- Postgres (local container / docker compose) ---
POSTGRES_USER=careeros
POSTGRES_PASSWORD=careeros
POSTGRES_DB=careeros
POSTGRES_PORT=5432

# --- Application settings (env prefix CAREEROS_) ---
# Source of truth: shared/platform/careeros_platform/settings.py (T9).
# Every field on Settings must appear here.

CAREEROS_ENVIRONMENT=development
CAREEROS_LOG_LEVEL=INFO
CAREEROS_APP_NAME=career-os

# Required by api/worker (fail-fast if missing when running outside compose).
# docker compose sets an in-cluster URL automatically (host `postgres`);
# use this localhost URL when running api/worker on the host against compose Postgres.
CAREEROS_DATABASE_URL=postgresql://careeros:careeros@localhost:5432/careeros

# api bind + port (compose forces host 0.0.0.0 inside the container).
CAREEROS_API_HOST=127.0.0.1
CAREEROS_API_PORT=8000

# --- Ports published to the host (docker compose only) ---
WEB_PORT=3000
