{
  "name": "career-os",
  "version": "0.0.0",
  "private": true,
  "description": "CareerOS monorepo — JS/TS workspace root (see AGENTS.md and docs/technical-architecture.md)",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint:py": "uv run ruff check . && uv run ruff format --check .",
    "typecheck:py": "uv run python scripts/typecheck_python.py",
    "test:py": "uv run pytest",
    "eval:gate": "uv run python evals/run_gate.py",
    "contracts:generate": "pnpm --filter @career-os/contracts generate",
    "contracts:check": "pnpm --filter @career-os/contracts check"
  },
  "devDependencies": {
    "turbo": "2.10.5"
  }
}
