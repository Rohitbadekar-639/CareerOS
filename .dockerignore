# Keep Docker build contexts small and reproducible (M0-T13).

# VCS / CI
.git
.github

# Python artifacts
**/__pycache__
**/*.py[cod]
**/*.egg-info
**/.venv
.venv
**/.mypy_cache
**/.ruff_cache
**/.pytest_cache
**/.coverage
dist
**/dist

# Node / Next artifacts (rebuilt inside the image)
**/node_modules
**/.next
**/.turbo
**/build
**/*.tsbuildinfo
**/next-env.d.ts

# Secrets / local env (never bake into an image)
.env
.env.*
!.env.example

# Editor / OS
.vscode
.idea
**/.DS_Store
Thumbs.db

# Docker + compose (not needed inside images)
infra/docker
docker-compose*.yml
compose*.yml
