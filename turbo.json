{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "generate": {
      "cache": false,
      "outputs": ["openapi.json", "src/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
